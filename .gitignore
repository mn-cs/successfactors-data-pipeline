build/
dist/
*.egg-info/

# Testing
.pytest_cache/

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
.venv/
.venv.nosync/

# =============================================================================
# DATA SCIENCE & JUPYTER
# =============================================================================
# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# JupySQL connection profiles
.jupysql/

# =============================================================================
